# Doktores runs fully offline by default (deterministic MockLLM) - no key needed for tests,
# CI, or a fresh clone. Set the switch below only when you want the real language layer.

# Turn on the real, OpenAI-compatible language layer (otherwise the MockLLM is used).
# DOKTORES_USE_REAL_LLM=1

# One key is enough; priority is DEEPSEEK_API_KEY > OPENROUTER_API_KEY > OPENAI_API_KEY.
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# Optional: override the model (e.g. an OpenRouter slug) and tune the transient retry.
# DOKTORES_MODEL=deepseek/deepseek-chat
# DOKTORES_LLM_RETRIES=4
# DOKTORES_LLM_BACKOFF=0.5
